{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "U2C Beatstore",
  "short_name": "Beatstore",
  "description": "U2C's beat library, projects, sends, and studio — all in one place.",
  "start_url": "/store",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0a0907",
  "theme_color": "#0a0907",
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ]
}
